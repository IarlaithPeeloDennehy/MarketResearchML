# ── NUMRKT ML Backend — environment variables ──────────────────────────────
#
# Copy this file to .env for local development.
# On Render these are set via the dashboard or render.yaml.
# NEVER commit a .env file with real credentials.

# PostgreSQL connection string.
# Render provides this automatically when you link a database.
# For local dev: spin up Postgres and fill in your credentials.
# Note: Render supplies postgres:// — the app converts it to postgresql:// automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/numrkt

# CORS — comma-separated list of allowed frontend origins.
# Leave empty when serving the frontend from this same FastAPI app (default).
# Only set this if you run a separate frontend domain.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=

# Cache directory for price data (parquet) and fundamentals (JSON).
# Leave empty to use backend/cache/ relative to main.py.
# On Render free tier the filesystem is ephemeral — point this at a
# persistent disk mount if you want the cache to survive deploys.
# Example: CACHE_DIR=/var/data/numrkt-cache
CACHE_DIR=

# Secret key — used to sign tokens / CSRF values (future use).
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
# Render generates this automatically via render.yaml (generateValue: true).
SECRET_KEY=
